# IBM watsonx credentials
# Obtain these from IBM Cloud: https://cloud.ibm.com/
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM watsonx Model
# Using GPT-OSS 120B (meta-llama/llama-3-3-70b-instruct via watsonx)
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# Flask settings
FLASK_SECRET_KEY=change_this_to_a_random_secret_key
FLASK_DEBUG=False
FLASK_ENV=production

# Optional: IBM watsonx Space ID (if using deployment space instead of project)
# WATSONX_SPACE_ID=your_space_id_here
